{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist",
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"types": ["node"],
		"composite": true
	},
	"include": ["src"],
	"references": [{ "path": "../db" }]
}
